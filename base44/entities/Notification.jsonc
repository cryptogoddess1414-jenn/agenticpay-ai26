{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Recipient user email"
    },
    "title": {
      "type": "string",
      "description": "Notification title"
    },
    "message": {
      "type": "string",
      "description": "Notification body"
    },
    "type": {
      "type": "string",
      "enum": [
        "system",
        "subscription",
        "activity",
        "alert"
      ],
      "default": "system"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "link": {
      "type": "string",
      "description": "Optional action URL"
    }
  },
  "required": [
    "user_email",
    "title",
    "message",
    "type"
  ]
}