{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "description": "Amount in USD"
    },
    "type": {
      "type": "string",
      "enum": [
        "charge",
        "refund",
        "payout"
      ],
      "default": "charge"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "pending",
        "refunded"
      ],
      "default": "succeeded"
    },
    "plan": {
      "type": "string",
      "enum": [
        "free",
        "starter",
        "pro",
        "enterprise"
      ]
    },
    "date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "user_email",
    "amount",
    "type",
    "status"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "data.user_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}